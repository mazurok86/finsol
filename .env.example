# Producer service
PRODUCER_HTTP_PORT=3000

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_EVENTS_QUEUE=events_queue
RABBITMQ_NOTIFICATIONS_QUEUE=notifications_queue

# Producer publish behavior
PUBLISH_MAX_RETRIES=5
PUBLISH_RETRY_DELAY_MS=500

# Consumer behavior
CONSUMER_MAX_RETRIES=3
CONSUMER_RETRY_DELAY_MS=1000

# Notification (Telegram) retry behavior
NOTIFICATION_MAX_RETRIES=3
NOTIFICATION_RETRY_DELAY_MS=1000

# Redis (producer idempotency)
REDIS_HOST=redis
REDIS_PORT=6379
PRODUCER_IDEMPOTENCY_TTL_SEC=86400
PRODUCER_IDEMPOTENCY_WAIT_TIMEOUT_MS=10000
PRODUCER_IDEMPOTENCY_POLL_INTERVAL_MS=100

# Telegram
TELEGRAM_BOT_TOKEN=replace_with_real_token
TELEGRAM_CHAT_ID=replace_with_real_chat_id
TELEGRAM_API_URL=https://api.telegram.org

# Common
NODE_ENV=development
LOG_LEVEL=debug
